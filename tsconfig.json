{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.astro",
    "astro.config.mjs",
    "infra/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "dist"]
}
